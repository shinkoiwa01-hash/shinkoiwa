<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>毎日更新チェックシート</title>
  <style>
    :root {
      --bg: #f4f6f8;
      --card: #ffffff;
      --text: #222;
      --muted: #6b7280;
      --line: #e5e7eb;
      --accent: #2563eb;
      --done: #16a34a;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN",
        "Yu Gothic", Meiryo, sans-serif;
      color: var(--text);
      background: var(--bg);
    }
    main {
      width: min(920px, calc(100% - 24px));
      margin: 32px auto;
    }
    h1 {
      margin: 0 0 22px;
      font-size: clamp(24px, 5vw, 38px);
    }
    .panel {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 18px;
      box-shadow: 0 8px 24px rgba(0,0,0,.04);
    }
    .assignee {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }
    select, button {
      font: inherit;
    }
    select {
      min-width: 180px;
      padding: 10px 12px;
      border: 1px solid #cbd5e1;
      border-radius: 10px;
      background: #fff;
    }
    details {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 14px;
      margin-bottom: 14px;
      overflow: hidden;
    }
    summary {
      cursor: pointer;
      font-weight: 700;
      padding: 16px 18px;
      user-select: none;
    }
    .tasks {
      padding: 0 18px 16px;
      display: grid;
      gap: 10px;
    }
    .task {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 13px 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fafafa;
    }
    .task input {
      width: 20px;
      height: 20px;
      accent-color: var(--done);
      flex: 0 0 auto;
    }
    .task:has(input:checked) {
      background: #f0fdf4;
      border-color: #bbf7d0;
    }
    .task:has(input:checked) span {
      color: var(--muted);
      text-decoration: line-through;
    }
    .reset {
      width: 100%;
      border: 0;
      border-radius: 12px;
      padding: 14px 18px;
      background: #111827;
      color: #fff;
      font-weight: 700;
      cursor: pointer;
    }
    .reset:hover { opacity: .9; }
    .links {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 10px;
    }
    .links a {
      display: block;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 10px;
      color: var(--accent);
      text-decoration: none;
      background: #fff;
    }
    .links a:hover { background: #eff6ff; }
    .note {
      margin-top: 14px;
      color: var(--muted);
      font-size: 13px;
    }
  </style>
</head>
<body>
  <main>
    <h1>毎日更新チェックシート</h1>

    <section class="panel assignee">
      <label for="assignee"><strong>担当者：</strong></label>
      <select id="assignee">
        <option value="">（未選択）</option>
        <option>角田</option>
        <option>坪</option>
        <option>羽田</option>
        <option>松丸</option>
        <option>久具</option>
        <option>西野</option>
        <option>金井</option>
      </select>
    </section>

    <details open>
      <summary>ランキング変更（ポータル）</summary>
      <div class="tasks">
        <label class="task"><input type="checkbox" data-key="cityheaven-kinshicho"><span>シティヘブン錦糸町 — ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="cityheaven-shinkoiwa"><span>シティヘブン新小岩 — ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="deli-koiwa"><span>デリヘルじゃぱん小岩【lovesele01】— ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="deli-shinkoiwa"><span>デリヘルじゃぱん新小岩【lovesele】— ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="deli-kasai"><span>デリヘルじゃぱん葛西【loves2525】— ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="fuzoku-japan"><span>風俗じゃぱん — ピックアップ変更</span></label>
        <label class="task"><input type="checkbox" data-key="ekichika"><span>駅ちか — ランキング変更</span></label>
        <label class="task"><input type="checkbox" data-key="fujoho"><span>口コミ情報局 — ピックアップ変更</span></label>
      </div>
    </details>

    <details open>
      <summary>HP作業</summary>
      <div class="tasks">
        <label class="task"><input type="checkbox" data-key="pickup"><span>ピックアップ — ピックアップ変更</span></label>
        <label class="task"><input type="checkbox" data-key="pickup-movie"><span>ピックアップムービー — ピックアップムービー変更</span></label>
        <label class="task"><input type="checkbox" data-key="reviews-sort"><span>口コミ — 口コミ並び替え変更</span></label>
        <label class="task"><input type="checkbox" data-key="vanilla-review"><span>口コミ — バニラ女性目線口コミ（1日1回）</span></label>
      </div>
    </details>

    <section class="panel">
      <button class="reset" id="resetButton" type="button">今日のチェックをリセット</button>
    </section>

    <section class="panel">
      <h2>各媒体リンク</h2>
      <div class="links">
        <a href="https://www.cityheaven.net/" target="_blank" rel="noopener">シティヘブン錦糸町</a>
        <a href="https://www.cityheaven.net/" target="_blank" rel="noopener">シティヘブン新小岩</a>
        <a href="https://deli-fuzoku.jp/" target="_blank" rel="noopener">デリヘルじゃぱん小岩【lovesele01】</a>
        <a href="https://deli-fuzoku.jp/" target="_blank" rel="noopener">デリヘルじゃぱん新小岩【lovesele】</a>
        <a href="https://deli-fuzoku.jp/" target="_blank" rel="noopener">デリヘルじゃぱん葛西【loves2525】</a>
        <a href="https://fuzoku.jp/" target="_blank" rel="noopener">風俗じゃぱん</a>
        <a href="https://ranking-deli.jp/" target="_blank" rel="noopener">駅ちか</a>
        <a href="https://fujoho.jp/" target="_blank" rel="noopener">口コミ情報局</a>
        <a href="https://qzin.jp/" target="_blank" rel="noopener">バニラ錦</a>
        <a href="https://qzin.jp/" target="_blank" rel="noopener">バニラ西</a>
        <a href="https://qzin.jp/" target="_blank" rel="noopener">バニラ新</a>
        <a href="https://qzin.jp/" target="_blank" rel="noopener">バニラ葛</a>
        <a href="https://qzin.jp/" target="_blank" rel="noopener">バニラ船</a>
      </div>
      <p class="note">※本日のチェック状態は端末ごとに保存されます</p>
    </section>
  </main>

  <script>
    const dateKey = new Date().toISOString().slice(0, 10);
    const storageKey = `daily-checksheet-${dateKey}`;
    const assigneeKey = `daily-checksheet-assignee-${dateKey}`;
    const checkboxes = [...document.querySelectorAll('input[type="checkbox"][data-key]')];
    const assignee = document.getElementById('assignee');

    function loadState() {
      const saved = JSON.parse(localStorage.getItem(storageKey) || '{}');
      checkboxes.forEach(box => box.checked = Boolean(saved[box.dataset.key]));
      assignee.value = localStorage.getItem(assigneeKey) || '';
    }

    function saveState() {
      const state = {};
      checkboxes.forEach(box => state[box.dataset.key] = box.checked);
      localStorage.setItem(storageKey, JSON.stringify(state));
    }

    checkboxes.forEach(box => box.addEventListener('change', saveState));
    assignee.addEventListener('change', () => {
      localStorage.setItem(assigneeKey, assignee.value);
    });

    document.getElementById('resetButton').addEventListener('click', () => {
      if (!confirm('本日のチェック状態をリセットしますか？')) return;
      checkboxes.forEach(box => box.checked = false);
      assignee.value = '';
      localStorage.removeItem(storageKey);
      localStorage.removeItem(assigneeKey);
    });

    loadState();
  </script>
</body>
</html>
